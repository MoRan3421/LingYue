{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LingYueInfinite",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "category": "Games",
      "copyright": "Ling Yue Independent Studio",
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.lingyue.infinite",
      "longDescription": "Ling Yue: Wu Liang Wu Jin - The Ultimate 3A MOBA Ecosystem.",
      "resources": [],
      "shortDescription": "Sovereign MOBA App",
      "targets": ["msi", "appimage", "dmg", "apk", "nsis"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": true,
        "transparent": false,
        "title": "灵约：无量无尽 (LING YUE)",
        "width": 1920,
        "height": 1080
      }
    ]
  }
}
